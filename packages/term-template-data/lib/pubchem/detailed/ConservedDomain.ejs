<% // https://github.com/idsm-src/server/blob/develop/service/src/main/webapp/templates/page/pubchem/ConservedDomain.vm

const title = (await select(`
  PREFIX dcterms: <http://purl.org/dc/terms/>
  PREFIX pubchem: <http://rdf.ncbi.nlm.nih.gov/pubchem/>

  SELECT ?title FROM pubchem:conserveddomain WHERE
  {
    ?entity dcterms:title ?title
  }
`, [{ entity }])).at(0)?.title

const abstract = (await select(`
  PREFIX dcterms: <http://purl.org/dc/terms/>
  PREFIX pubchem: <http://rdf.ncbi.nlm.nih.gov/pubchem/>

  SELECT ?abstract FROM pubchem:conserveddomain WHERE
  {
    ?entity dcterms:abstract ?abstract
  }
`, [{ entity }])).at(0)?.abstract

const pubChemUrl = entity.value.replace(/.+\/PSSMID(.+)$/, 'https://www.ncbi.nlm.nih.gov/Structure/cdd/cddsrv.cgi?uid=$1')
%>

<table>
  <tbody>
    <tr>
      <th>PubChem</th>
      <td>
        <a href="<%= pubChemUrl %>"><%= pubChemUrl %></a>
      </td>
    </tr>
    <% if (title) { %>
    <tr>
      <th>Title</th>
      <td><%- await visualise(title) %></td>
    </tr>
    <% } %>
    <% if (abstract) { %>
    <tr>
      <th>Abstract</th>
      <td><%- await visualise(abstract) %></td>
    </tr>
    <% } %>
  </tbody>
</table>