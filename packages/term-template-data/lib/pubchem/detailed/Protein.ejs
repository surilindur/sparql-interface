<% // https://github.com/idsm-src/server/blob/develop/service/src/main/webapp/templates/page/pubchem/Protein.vm

const labelVisualisations = (await querySelectAll(`
  PREFIX pubchem: <http://rdf.ncbi.nlm.nih.gov/pubchem/>
  PREFIX skos: <http://www.w3.org/2004/02/skos/core#>

  SELECT DISTINCT ?label FROM pubchem:protein WHERE
  {
    ?entity skos:prefLabel ?label
  }
`, [{ entity }])).map(b => visualise(b.label))

const organismVisualisations = (await querySelectAll(`
  PREFIX pubchem: <http://rdf.ncbi.nlm.nih.gov/pubchem/>
  PREFIX up: <http://purl.uniprot.org/core/>

  SELECT DISTINCT ?organism FROM pubchem:protein WHERE
  {
    ?entity up:organism ?organism
  }
`, [{ entity }])).map(b => visualise(b.organism))

const pathwayVisualisations = (await querySelectAll(`
  PREFIX bp: <http://www.biopax.org/release/biopax-level3.owl#>
  PREFIX obo: <http://purl.obolibrary.org/obo/>
  PREFIX pubchem: <http://rdf.ncbi.nlm.nih.gov/pubchem/>
  PREFIX rdf: <http://www.w3.org/1999/02/22-rdf-syntax-ns#>

  SELECT DISTINCT ?pathway FROM pubchem:pathway WHERE
  {
    ?pathway rdf:type bp:Pathway.
    ?pathway obo:RO_0000057 ?entity.
  }
`, [{ entity }])).map(b => visualise(b.pathway))

const pubChemUrl = entity.value.replace(/.+\/ACC(.+)$/, 'https://www.ncbi.nlm.nih.gov/protein/$1')
%>

<table>
  <tr>
    <th>PubChem</th>
    <td>
      <a href="<%= pubChemUrl %>"><%= pubChemUrl %></a>
    </td>
  </tr>
  <% if (labelVisualisations.length > 0) { %>
  <tr>
    <th>Labels</th>
    <td>
      <% for (const visualisation of labelVisualisations) { %>
      <%- await visualisation %>
      <% } %>
    </td>
  </tr>
  <% } %>
  <% if (organismVisualisations.length > 0) { %>
  <tr>
    <th>Organisms</th>
    <td>
      <% for (const visualisation of organismVisualisations) { %>
      <%- await visualisation %>
      <% } %>
    </td>
  </tr>
  <% } %>
  <% if (pathwayVisualisations.length > 0) { %>
  <tr>
    <th>Pathways</th>
    <td>
      <% for (const visualisation of pathwayVisualisations) { %>
      <%- await visualisation %>
      <% } %>
    </td>
  </tr>
  <% } %>
</table>