<% // https://github.com/idsm-src/server/blob/develop/service/src/main/webapp/templates/page/pubchem/Compound.vm

const name = await querySelectFirst(`
  PREFIX descriptor: <http://rdf.ncbi.nlm.nih.gov/pubchem/descriptor/>
  PREFIX pubchem: <http://rdf.ncbi.nlm.nih.gov/pubchem/>
  PREFIX rdf: <http://www.w3.org/1999/02/22-rdf-syntax-ns#>
  PREFIX sio: <http://semanticscience.org/resource/>

  SELECT ?name FROM pubchem:compound FROM descriptor:compound WHERE
  {
    ?entity sio:SIO_000008 ?D.
    ?D rdf:type sio:CHEMINF_000382.
    ?D sio:SIO_000300 ?name.
  }
`, [{ entity }])

const structuresExist = await queryAsk(`
  PREFIX pubchem: <http://rdf.ncbi.nlm.nih.gov/pubchem/>
  PREFIX rdf: <http://www.w3.org/1999/02/22-rdf-syntax-ns#>
  PREFIX sio: <http://semanticscience.org/resource/>

  ASK FROM pubchem:compound WHERE
  {
    ?S rdf:type sio:SIO_011120.
    ?S sio:SIO_000011 ?entity.
    ?S sio:SIO_000300 ?V.
  }
`, [{ entity }])

const descriptorVisualisations = (await querySelectAll(`
  PREFIX descriptor: <http://rdf.ncbi.nlm.nih.gov/pubchem/descriptor/>
  PREFIX pubchem: <http://rdf.ncbi.nlm.nih.gov/pubchem/>
  PREFIX rdf: <http://www.w3.org/1999/02/22-rdf-syntax-ns#>
  PREFIX sio: <http://semanticscience.org/resource/>

  SELECT ?title ?value FROM pubchem:compound FROM descriptor:compound WHERE
  {
    ?entity sio:SIO_000008 ?D.
    ?D rdf:type ?type.
    ?D sio:SIO_000300 ?value.
  }
  VALUES (?type ?title)
  {
    (sio:CHEMINF_000335 "molecular formula")
    (sio:CHEMINF_000379 "SMILES")
    (sio:CHEMINF_000376 "connectivity SMILES")
    (sio:CHEMINF_000396 "IUPAC InChI")
    (sio:CHEMINF_000338 "exact mass")
    (sio:CHEMINF_000334 "molecular weight")
    (sio:CHEMINF_000337 "monoisotopic weight")
    (sio:CHEMINF_000336 "total formal charge")
    (sio:CHEMINF_000395 "XLogP3(-AA)")
    (sio:CHEMINF_000392 "TPSA")
    (sio:CHEMINF_000390 "structure complexity")
    (sio:CHEMINF_000388 "hydrogen bond acceptor count")
    (sio:CHEMINF_000370 "defined atom stereo count")
    (sio:CHEMINF_000371 "defined bond stereo count")
    (sio:CHEMINF_000375 "undefined bond stereo count")
    (sio:CHEMINF_000372 "isotope atom count")
    (sio:CHEMINF_000369 "covalent unit count")
    (sio:CHEMINF_000387 "hydrogen bond donor count")
    (sio:CHEMINF_000373 "non-hydrogen atom count")
    (sio:CHEMINF_000389 "rotatable bond count")
    (sio:CHEMINF_000374 "undefined atom stereo count")
  }
`, [{ entity }])).map(d => ({ title: d.title.value, value: visualise(d.value) }))

const synonymVisualisations = (await querySelectAll(`
  PREFIX pubchem: <http://rdf.ncbi.nlm.nih.gov/pubchem/>
  PREFIX sio: <http://semanticscience.org/resource/>

  SELECT ?name FROM pubchem:synonym WHERE
  {
    ?A sio:SIO_000011 ?entity.
    ?A sio:SIO_000300 ?name.
  }
`, [{ entity }])).map(s => visualise(s.name))

const regex = /.+\/CID(.+)$/
const pubChemUrl = entity.value.replace(regex, 'https://pubchem.ncbi.nlm.nih.gov/compound/$1')
const imageUrl = entity.value.replace(regex, 'https://idsm.elixir-czech.cz/chemweb/pubchem/compound/svg?id=$1')
%>

<h1><%= name?.name?.value ?? entity.value %><small><a rel="external" href="<%= pubChemUrl %>">PubChem</a></small></h1>

<% if (structuresExist) { %>
  <object data="<%= imageUrl %>" type="image/svg+xml"></object>
<% } %>

<% if (synonymVisualisations.length > 0) { %>
<h2>Synonyms</h2>
<table>
  <tbody>
    <% for (const visualisation of synonymVisualisations) { %>
    <tr>
      <td>
        <%- await visualisation %>
      </td>
    </tr>
    <% } %>
  </tbody>
</table>
<% } %>

<% if (descriptorVisualisations.length > 0) { %>
<h2>Descriptors</h2>

<table>
  <tbody>
    <% for (const visualisation of descriptorVisualisations) { %>
    <tr>
      <th><%= visualisation.title %></th>
      <td><%- await visualisation.value %></td>
    </tr>
    <% } %>
  </tbody>
</table>
<% } %>