<% // https://github.com/idsm-src/server/blob/develop/service/src/main/webapp/templates/page/pubchem/Bioassay.vm

const title = (await select(`
  PREFIX dcterms: <http://purl.org/dc/terms/>
  PREFIX pubchem: <http://rdf.ncbi.nlm.nih.gov/pubchem/>

  SELECT ?title FROM pubchem:bioassay WHERE
  {
    ?entity dcterms:title ?title
  }
`, [{ entity }])).at(0)?.title

const description = (await select(`
  PREFIX pubchem: <http://rdf.ncbi.nlm.nih.gov/pubchem/>
  PREFIX rdf: <http://www.w3.org/1999/02/22-rdf-syntax-ns#>
  PREFIX sio: <http://semanticscience.org/resource/>

  SELECT ?value FROM pubchem:bioassay WHERE
  {
    ?D sio:SIO_000011 ?entity.
    ?D rdf:type sio:SIO_000136.
    ?D sio:SIO_000300 ?value.
  }
`, [{ entity }])).at(0)?.value?.value

const protocol = (await select(`
  PREFIX pubchem: <http://rdf.ncbi.nlm.nih.gov/pubchem/>
  PREFIX rdf: <http://www.w3.org/1999/02/22-rdf-syntax-ns#>
  PREFIX sio: <http://semanticscience.org/resource/>

  SELECT ?value FROM pubchem:bioassay WHERE
  {
    ?D sio:SIO_000011 ?entity.
    ?D rdf:type sio:SIO_001041.
    ?D sio:SIO_000300 ?value.
  }
`, [{ entity }])).at(0)?.value?.value

const comment = (await select(`
  PREFIX pubchem: <http://rdf.ncbi.nlm.nih.gov/pubchem/>
  PREFIX rdf: <http://www.w3.org/1999/02/22-rdf-syntax-ns#>
  PREFIX sio: <http://semanticscience.org/resource/>

  SELECT ?value FROM pubchem:bioassay WHERE
  {
    ?D sio:SIO_000011 ?entity.
    ?D rdf:type sio:SIO_001167.
    ?D sio:SIO_000300 ?value.
  }
`, [{ entity }])).at(0)?.value?.value

const pubChemUrl = entity.value.replace(/.+\/AID(.+)$/, 'https://pubchem.ncbi.nlm.nih.gov/bioassay/$1')
%>

<table>
  <tbody>
    <tr>
      <th>PubChem</th>
      <td>
        <a href="<%= pubChemUrl %>"><%= pubChemUrl %></a>
      </td>
    </tr>
    <% if (title) { %>
    <tr>
      <th>Title</th>
      <td><%- await visualise(title) %></td>
    </tr>
    <% } %>
    <% if (description) { %>
    <tr>
      <th>Description</th>
      <td class="prewrap"><%= description %></td>
    </tr>
    <% } %>
    <% if (protocol) { %>
    <tr>
      <th>Protocol</th>
      <td class="prewrap"><%= protocol %></td>
    </tr>
    <% } %>
    <% if (comment) { %>
    <tr>
      <th>Comment</th>
      <td class="prewrap"><%= comment %></td>
    </tr>
    <% } %>
  </tbody>
</table>