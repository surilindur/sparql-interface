<% // Generic template for named nodes

const namedNode = await querySelectFirst(`
  PREFIX rdfs: <http://www.w3.org/2000/01/rdf-schema#>

  SELECT ?label WHERE
  {
    ?entity rdfs:label ?label .
  }
`, [{ entity }])
%>

<a href="<%= entity.value %>"><%= namedNode?.label?.value ?? entity.value %></a>