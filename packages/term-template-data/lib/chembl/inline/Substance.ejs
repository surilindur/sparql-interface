<% // https://github.com/idsm-src/server/blob/develop/service/src/main/webapp/templates/item/chembl/Substance.vm

const label = await querySelectFirst(`
  PREFIX ebi: <http://rdf.ebi.ac.uk/dataset/>
  PREFIX rdfs: <http://www.w3.org/2000/01/rdf-schema#>

  SELECT ?label FROM ebi:chembl WHERE
  {
    ?entity rdfs:label ?label .
    FILTER(!STRSTARTS(?label, "CHEMBL"))
  }
`, [{ entity }])

const structuresExist = await queryAsk(`
  PREFIX ebi: <http://rdf.ebi.ac.uk/dataset/>
  PREFIX rdf: <http://www.w3.org/1999/02/22-rdf-syntax-ns#>
  PREFIX sio: <http://semanticscience.org/resource/>

  ASK FROM ebi:chembl WHERE
  {
    ?S rdf:type sio:SIO_011120 .
    ?S sio:SIO_000011 ?entity .
    ?S sio:SIO_000300 ?V .
  }
`, [{ entity }])

const imageUrl = entity.value.replace(/.+\/CHEMBL([0-9]+)$/, 'https://idsm.elixir-czech.cz/chemweb/chembl/compound/svg?id=$1')
%>

<% if (structuresExist) { %>
<object data="<%= imageUrl %>" type="image/svg+xml"></object>
<% } %>

<a href="<%= entity.value %>"><%= label?.label?.value ?? entity.value %></a>
