<% // https://github.com/idsm-src/server/blob/develop/service/src/main/webapp/templates/page/chembl/Substance.vm

const label = await querySelectFirst(`
  PREFIX ebi: <http://rdf.ebi.ac.uk/dataset/>
  PREFIX skos: <http://www.w3.org/2004/02/skos/core#>

  SELECT DISTINCT ?label FROM ebi:chembl WHERE
  {
    ?entity skos:prefLabel ?label .
  }
`, [{ entity }])

const structuresExist = await queryAsk(`
  PREFIX ebi: <http://rdf.ebi.ac.uk/dataset/>
  PREFIX rdf: <http://www.w3.org/1999/02/22-rdf-syntax-ns#>
  PREFIX sio: <http://semanticscience.org/resource/>

  ASK FROM ebi:chembl WHERE
  {
    ?S rdf:type sio:SIO_011120.
    ?S sio:SIO_000011 ?entity.
    ?S sio:SIO_000300 ?V.
  }
`, [{ entity }])

const descriptorVisualisations = (await querySelectAll(`
  PREFIX ebi: <http://rdf.ebi.ac.uk/dataset/>
  PREFIX rdf: <http://www.w3.org/1999/02/22-rdf-syntax-ns#>
  PREFIX sio: <http://semanticscience.org/resource/>

  SELECT ?title ?value FROM ebi:chembl WHERE
  {
    ?entity sio:SIO_000008 ?D.
    ?D rdf:type ?type.
    ?D sio:SIO_000300 ?value.
    VALUES (?type ?title ?D)
    {
      (sio:CHEMINF_000195 "ChemAxon most acidic pKa" <${entity.value}#cx_most_apka>)
      (sio:CHEMINF_000195 "ChemAxon most basic pKa" <${entity.value}#cx_most_bpka>)
      (sio:CHEMINF_000322 "ChemAxon LogD" UNDEF)
      (sio:CHEMINF_000251 "ChemAxon LogP" <${entity.value}#cx_logp>)
      (sio:CHEMINF_000251 "ALogP" <${entity.value}#alogp>)
      (sio:CHEMINF_000245 "hydrogen bond acceptors" UNDEF)
      (sio:CHEMINF_000244 "hydrogen bond donors" UNDEF)
      (sio:CHEMINF_000300 "heavy atoms" UNDEF)
      (sio:CHEMINF_000254 "rotatable bonds" UNDEF)
      (sio:CHEMINF_000381 "aromatic rings" UNDEF)
      (sio:CHEMINF_000350 "freebase molecular weight" UNDEF)
      (sio:CHEMINF_000216 "full molecular weight" UNDEF)
      (sio:CHEMINF_000218 "monoisotopic mass" UNDEF)
      (sio:CHEMINF_000307 "polar surface area" UNDEF)
      (sio:CHEMINF_000312 "RO5 violations" UNDEF)
      (sio:CHEMINF_000315 "RO3 pass" UNDEF)
      (sio:CHEMINF_000431 "QED weighted score" UNDEF)
      (sio:CHEMINF_000326 "molecular species" UNDEF)
      (sio:CHEMINF_000042 "molecular formula" UNDEF)
      (sio:CHEMINF_000059 "standard InChi Key" UNDEF)
      (sio:CHEMINF_000113 "standard InChi" UNDEF)
      (sio:CHEMINF_000018 "canonical smiles" UNDEF)
    }
  }
`, [{ entity }])).map(b => ({ title: b.title.value, value: visualise(b.value) }))

const synonymVisualisations = (await querySelectAll(`
  PREFIX skos: <http://www.w3.org/2004/02/skos/core#>

  SELECT DISTINCT ?name WHERE
  {
    ?entity skos:altLabel ?name.
  }
`, [{ entity }])).map(b => visualise(b.name))

const regex = /.+\/CHEMBL(.+)$/
const chemblUrl = entity.value.replace(regex, 'https://www.ebi.ac.uk/chembl/explore/compound/CHEMBL$1')
const imageUrl = entity.value.replace(regex, 'https://idsm.elixir-czech.cz/chemweb/chembl/compound/svg?id=$1')
%>

<h2>
  <a href="<%= entity.value %>"><%= label?.label?.value ?? entity.value %></a>
  <small>
    (<a rel="external" href="<%= chemblUrl %>">ChEMBL</a>)
  </small>
</h2>

<% if (structuresExist) { %>
<object data="<%= imageUrl %>" type="image/svg+xml"></object>
<% } %>

<% if (synonymVisualisations.length > 0) { %>
<h2>Synonyms</h2>
<table>
  <tbody>
    <% for (const visualisation of synonymVisualisations) { %>
    <tr>
      <td>
        <%- await visualisation %>
      </td>
    </tr>
    <% } %>
  </tbody>
</table>
<% } %>

<% if (descriptorVisualisations.length > 0) { %>
<h2>Descriptors</h2>
<table>
  <tbody>
    <% for (const descriptor of descriptorVisualisations) { %>
    <tr>
      <th><%= descriptor.title %></th>
      <td><%- await descriptor.value %></td>
    </tr>
    <% } %>
  </tbody>
</table>
<% } %>