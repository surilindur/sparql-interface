<% // https://github.com/idsm-src/server/blob/develop/service/src/main/webapp/templates/item/mona/Experiment.vm

const name = await querySelectFirst(`
  PREFIX mona: <https://idsm.elixir-czech.cz/rdf/mona/>
  PREFIX rdf: <http://www.w3.org/1999/02/22-rdf-syntax-ns#>
  PREFIX sio: <http://semanticscience.org/resource/>

  SELECT ?name FROM mona: WHERE
  {
    ?entity sio:SIO_000230 / sio:SIO_000008 ?D .
    ?D rdf:type sio:CHEMINF_000043 .
    ?D sio:SIO_000300 ?label .
  }
`, [{ entity }])

const structuresExist = await ask(`
  PREFIX mona: <https://idsm.elixir-czech.cz/rdf/mona/>
  PREFIX rdf: <http://www.w3.org/1999/02/22-rdf-syntax-ns#>
  PREFIX sio: <http://semanticscience.org/resource/>

  ASK FROM mona: WHERE
  {
    ?entity sio:SIO_000230 / sio:SIO_000008 ?S.
    ?S rdf:type sio:SIO_011120.
    ?S sio:SIO_000300 ?V.
  }
`, [{ entity }])

const imageUrl = entity.value.replace(/.+\/(.+)_EXP$/, 'https://idsm.elixir-czech.cz/chemweb/mona/compound/svg?id=$1')
%>

<% if (structuresExist) { %>
<object data="<%= imageUrl %>" type="image/svg+xml"></object>
<% } %>

<a href="<%= entity.value %>"><%= name?.name?.value ?? entity.value %></a>
