<% // https://github.com/idsm-src/server/blob/develop/service/src/main/webapp/templates/item/mona/Descriptor.vm

const data = (await select(`
  PREFIX mona: <https://idsm.elixir-czech.cz/rdf/mona/>
  PREFIX obo: <http://purl.obolibrary.org/obo/>
  PREFIX sio: <http://semanticscience.org/resource/>

  SELECT ?value ?unit FROM mona: WHERE
  {
    ?entity sio:SIO_000300 ?value.

    OPTIONAL
    {
      ?entity sio:SIO_000221 ?unit_type.
      VALUES (?unit_type ?unit)
      {
        (obo:UO_0000055 "g/mol")
        (obo:UO_0000010 "s")
        (obo:UO_0000031 "min")
        (obo:UO_0000218 "V")
        (obo:UO_0000248 "kV")
        (obo:UO_0000266 "eV")
      }
    }
  }
`, [{ entity }])).at(0)

const name = `${data?.value?.value ?? ''} ${data?.unit?.value ?? ''}`.trim() ?? await queryLabel(entity)
%>

<a href="<%= entity.value %>"><%= name %></a>