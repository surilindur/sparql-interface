<% // https://github.com/idsm-src/server/blob/develop/service/src/main/webapp/templates/item/mona/Peak.vm

const data = (await select(`
  PREFIX mona: <https://idsm.elixir-czech.cz/rdf/mona/>
  PREFIX sio: <http://semanticscience.org/resource/>

  SELECT ?position ?annotation FROM mona: WHERE
  {
    ?entity sio:SIO_000056 ?position .
    ?entity sio:SIO_000255 / sio:SIO_000300 ?annotation .
  }
`, [{ entity }])).at(0)
%>

<a href="<%= entity.value %>"><%= await queryLabel(entity) %></a>

<% if (data) { %>
<small>peak at <%= data.position.value %> m/z (<%= data.annotation.value %>)</small>
<% } %>
