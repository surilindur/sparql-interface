<% // https://github.com/idsm-src/server/blob/develop/service/src/main/webapp/templates/page/mona/Experiment.vm

const nameVisualisations = (await select(`
  PREFIX rdf: <http://www.w3.org/1999/02/22-rdf-syntax-ns#>
  PREFIX mona: <https://idsm.elixir-czech.cz/rdf/mona/>
  PREFIX sio: <http://semanticscience.org/resource/>

  SELECT ?name FROM mona: WHERE
  {
    ?entity sio:SIO_000230 / sio:SIO_000008 ?D.
    ?D rdf:type sio:CHEMINF_000043.
    ?D sio:SIO_000300 ?name.
  }
  ORDER BY ?name
`, [{ entity }])).map(b => visualise(b.name))

const structuresExist = await ask(`
  PREFIX rdf: <http://www.w3.org/1999/02/22-rdf-syntax-ns#>
  PREFIX mona: <https://idsm.elixir-czech.cz/rdf/mona/>
  PREFIX sio: <http://semanticscience.org/resource/>

  ASK FROM mona: WHERE
  {
    ?entity sio:SIO_000230 / sio:SIO_000008 ?S.
    ?S rdf:type sio:SIO_011120.
    ?S sio:SIO_000300 ?V.
  }
`, [{ entity }])

const parameters = await select(`
  PREFIX rdf: <http://www.w3.org/1999/02/22-rdf-syntax-ns#>
  PREFIX mona: <https://idsm.elixir-czech.cz/rdf/mona/>
  PREFIX obo: <http://purl.obolibrary.org/obo/>
  PREFIX sio: <http://semanticscience.org/resource/>

  SELECT ?title ?value ?unit FROM mona: WHERE
  {
    {
      {
        ?entity sio:SIO_000552 ?D.
        ?D rdf:type ?type.
      }
      VALUES (?title ?type ?value)
      {
        ("scan" obo:MS_1000130 "positive")
        ("scan" obo:MS_1000129 "negative")
        ("ionization" obo:MS_1000070 "atmospheric pressure chemical ionization")
        ("ionization" obo:MS_1000071 "chemical ionization")
        ("ionization" obo:MS_1000073 "electrospray ionization")
        ("ionization" obo:MS_1000074 "fast atom bombardment ionization")
        ("ionization" obo:MS_1000075 "matrix-assisted laser desorption ionization")
        ("ionization" obo:MS_1000258 "field ionization")
        ("ionization" obo:MS_1000389 "electron ionization")
        ("ionization" obo:MS_1000398 "nanoelectrospray")
      }
    }
    UNION
    {
      {
        ?entity sio:SIO_000552 ?D.
        ?D rdf:type ?type.
        ?D sio:SIO_000300 ?value.
        
        OPTIONAL
        {
          ?D sio:SIO_000221 ?unit_type.
          VALUES (?unit_type ?unit)
          {
            (obo:UO_0000010 "s")
            (obo:UO_0000031 "min")
            (obo:UO_0000218 "V")
            (obo:UO_0000248 "kV")
            (obo:UO_0000266 "eV")
          }
        }
      }
      VALUES (?type ?title)
      {
        (obo:MS_1000511 "ms level")
        (obo:MS_1000894 "retention time")
        (obo:MS_1000045 "collision energy")
        (obo:MS_1000138 "normalized collision energy")
        (obo:MS_1002013 "collision energy ramp start")
        (obo:MS_1002218 "percent collision energy ramp start")
        (obo:MS_1002014 "collision energy ramp end")
        (obo:MS_1002219 "percent collision energy ramp end")
        (obo:MS_1000463 "instrument")
        (obo:MS_1000031 "instrument model")
        (obo:MS_1002813 "precursor type")
        (obo:MS_1000744 "precursor m/z")
      }
    }
  }
`, [{ entity }])

const tagVisualisations = (await select(`
  PREFIX mona: <https://idsm.elixir-czech.cz/rdf/mona/>
  PREFIX sio: <http://semanticscience.org/resource/>

  SELECT ?value FROM mona: WHERE
  {
    ?entity sio:SIO_000255 / sio:SIO_000300 ?value.
  }
`, [{ entity }])).map(b => visualise(b.value))

const regex = /.+\/(.+)_EXP$/
const imageUrl = entity.value.replace(regex, 'https://idsm.elixir-czech.cz/chemweb/mona/compound/svg?id=$1')
const spectrumUrl = entity.value.replace(regex, 'https://idsm.elixir-czech.cz/chemweb/mona/compound/spectrum?id=$1')
%>

<table>
  <tbody>
    <% if (nameVisualisations.length > 0) { %>
    <tr>
      <th>Names</th>
      <td>
        <% for (const visualisation of nameVisualisations) { %>
        <%- await visualisation %>
        <% } %>
      </td>
    </tr>
    <% } %>
    <% if (structuresExist) { %>
    <tr>
      <th>Structure</th>
      <td>
        <object data="<%= imageUrl %>" type="image/svg+xml"></object>
      </td>
    </tr>
    <% } %>
    <tr>
      <th>MS Chart</th>
      <td class="spectrum" data-source="<%= spectrumUrl %>"></td>
    </tr>
    <% if (tagVisualisations.length > 0) { %>
    <tr>
      <th>Tags</th>
      <td>
        <% for (const visualisation of tagVisualisations) { %>
        <%- await visualisation %>
        <% } %>
      </td>
    </tr>
    <% } %>
  </tbody>
</table>

<% if (parameters.length > 0) { %>
<h2>Parameters</h2>
<table>
  <tbody>
    <% for (const parameter of parameters) { %>
    <tr>
      <th><%= parameter.title.value %></th>
      <td class="prewrap"><%= `${parameter.value.value} ${parameter.unit?.value ?? ''}`.trim() %></td>
    </tr>
    <% } %>
  </tbody>
</table>
<% } %>