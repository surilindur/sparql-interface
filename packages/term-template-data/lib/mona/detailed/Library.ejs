<% // https://github.com/idsm-src/server/blob/develop/service/src/main/webapp/templates/page/mona/Library.vm

const description = (await select(`
  PREFIX dcterms: <http://purl.org/dc/terms/>
  PREFIX mona: <https://idsm.elixir-czech.cz/rdf/mona/>

  SELECT ?value FROM mona: WHERE
  {
    ?entity dcterms:description ?value
  }
`, [{ entity }])).at(0)?.value?.value
%>

<% if (description) { %>
<table>
  <tbody>
    <tr>
      <th>Description</th>
      <td class="prewrap"><%= description %></td>
    </tr>
  </tbody>
</table>
<% } %>