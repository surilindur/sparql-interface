<% // https://github.com/idsm-src/server/blob/develop/service/src/main/webapp/templates/item/chebi/Class.vm

const label = await querySelectFirst(`
  PREFIX ebi: <http://rdf.ebi.ac.uk/dataset/>
  PREFIX rdfs: <http://www.w3.org/2000/01/rdf-schema#>
  PREFIX skos: <http://www.w3.org/2004/02/skos/core#>

  SELECT DISTINCT ?label FROM ebi:chebi WHERE
  {
    ?entity skos:prefLabel|rdfs:label ?label .
  }
`, [{ entity }])

const structuresExist = await queryAsk(`
  PREFIX ebi: <http://rdf.ebi.ac.uk/dataset/>
  PREFIX rdf: <http://www.w3.org/1999/02/22-rdf-syntax-ns#>
  PREFIX sio: <http://semanticscience.org/resource/>

  ASK FROM ebi:chebi WHERE
  {
    ?S rdf:type sio:SIO_011120.
    ?S sio:SIO_000011 ?entity.
    ?S sio:SIO_000300 ?V.
  }
`, [{ entity }])

const imageUrl = entity.value.replace(/.+\/obo\/CHEBI_([0-9]+)$/, 'https://idsm.elixir-czech.cz/chemweb/chebi/compound/svg?id=$1')
%>

<% if (structuresExist) { %>
<object data="<%= imageUrl %>" type="image/svg+xml"></object>
<% } %>

<a href="<%= entity.value %>"><%= label?.label?.value ?? entity.value %></a>
