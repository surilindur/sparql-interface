<% // https://github.com/idsm-src/server/blob/develop/service/src/main/webapp/templates/page/isdb/Experiment.vm

const parameters = await select(`
  PREFIX isdb: <https://idsm.elixir-czech.cz/rdf/isdb/>
  PREFIX obo: <http://purl.obolibrary.org/obo/>
  PREFIX rdf: <http://www.w3.org/1999/02/22-rdf-syntax-ns#>
  PREFIX sio: <http://semanticscience.org/resource/>

  SELECT ?title ?value ?unit FROM isdb: WHERE
  {
    {
      {
        ?entity sio:SIO_000552 ?D.
        ?D rdf:type ?type.
      }
      VALUES (?title ?type ?value)
      {
        ("scan" obo:MS_1000130 "positive")
        ("scan" obo:MS_1000129 "negative")
        ("ionization" obo:MS_1000073 "electrospray ionization")
      }
    }
    UNION
    {
      {
        ?entity sio:SIO_000552 ?D.
        ?D rdf:type ?type.
        ?D sio:SIO_000300 ?value.
        
        OPTIONAL
        {
          ?D sio:SIO_000221 ?unit_type.
          VALUES (?unit_type ?unit)
          {
            (obo:UO_0000010 "s")
            (obo:UO_0000031 "min")
            (obo:UO_0000218 "V")
            (obo:UO_0000248 "kV")
            (obo:UO_0000266 "eV")
          }
        }
      }
      VALUES (?type ?title)
      {
        (obo:MS_1000511 "ms level")
        (obo:MS_1000463 "instrument")
        (obo:MS_1000031 "instrument model")
        (obo:MS_1002813 "precursor type")
        (obo:MS_1000041 "charge state")
        (obo:MS_1000744 "precursor m/z")
      }
    }
  }
`, [{ entity }])

const tagVisualisations = (await select(`
  PREFIX isdb: <https://idsm.elixir-czech.cz/rdf/isdb/>
  PREFIX sio: <http://semanticscience.org/resource/>

  SELECT ?value FROM isdb: WHERE
  {
    ?entity sio:SIO_000255 / sio:SIO_000300 ?value .
  }
`, [{ entity }])).map(b => visualise(b.value))

const regex = /.+\/(.+)_EXP$/
const imageId = entity.value.replace(regex, '$1').substring(0, 14)
const imageUrl = `https://idsm.elixir-czech.cz/chemweb/isdb/compound/svg?id=${imageId}`
const spectrumUrl = entity.value.replace(regex, 'https://idsm.elixir-czech.cz/chemweb/isdb/compound/spectrum?id=$1')
%>

<table>
  <tbody>
    <tr>
      <th>Structure</th>
      <td>
        <object data="<%= imageUrl %>" type="image/svg+xml"></object>
      </td>
    </tr>
    <tr>
      <th>MS Chart</th>
      <td class="spectrum" data-source="<%= spectrumUrl %>"></td>
    </tr>
    <% if (tagVisualisations.length > 0) { %>
    <tr>
      <th>Tags</th>
      <td>
        <% for (const visualisation of tagVisualisations) { %>
        <%- await visualisation %>
        <% } %>
      </td>
    </tr>
    <% } %>
  </tbody>
</table>