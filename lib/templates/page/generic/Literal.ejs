<% // Details template for a literal value %>

<h1><%= entity.termType %></h1>

<table>
  <tbody>
    <tr>
      <th>Value</th>
      <td><%= entity.value %></td>
    </tr>
    <tr>
      <th>Language</th>
      <td><%= entity.language %></td>
    </tr>
    <tr>
      <th>Direction</th>
      <td><%= entity.direction ?? '' %></td>
    </tr>
    <tr>
      <th>Datatype</th>
      <td>
        <% if (entity.datatype) { %>
        <%- await visualise(entity.datatype) %>
        <% } %>
      </td>
    </tr>
  </tbody>
</table>