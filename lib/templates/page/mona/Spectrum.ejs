<% // https://github.com/idsm-src/server/blob/develop/service/src/main/webapp/templates/page/mona/Spectrum.vm

const splashVisualisations = (await select(`
  PREFIX obo: <http://purl.obolibrary.org/obo/>
  PREFIX rdf: <http://www.w3.org/1999/02/22-rdf-syntax-ns#>
  PREFIX mona: <https://idsm.elixir-czech.cz/rdf/mona/>
  PREFIX sio: <http://semanticscience.org/resource/>

  SELECT ?value FROM mona: WHERE
  {
    ?entity sio:SIO_000008 ?S .
    ?S rdf:type obo:MS_1002599 .
    ?S sio:SIO_000300 ?value .
  }
`, [{ entity }])).map(b => visualise(b.value))

const peaks = await select(`
  PREFIX rdf: <http://www.w3.org/1999/02/22-rdf-syntax-ns#>
  PREFIX mona: <https://idsm.elixir-czech.cz/rdf/mona/>
  PREFIX sio: <http://semanticscience.org/resource/>

  SELECT ?position ?annotation FROM mona: WHERE
  {
    ?entity sio:SIO_000369 ?peak .
    ?peak sio:SIO_000056 ?position .
    ?peak sio:SIO_000255 / sio:SIO_000300 ?annotation .
  }
  ORDER BY ?position
`, [{ entity }])

const spectrumUrl = entity.value.replace(/.+\/(.+)_MS$/, 'https://idsm.elixir-czech.cz/chemweb/mona/compound/spectrum?id=$1')
%>

<table>
  <tbody>
    <% if (splashVisualisations.length > 0) { %>
    <tr>
      <th>Splash</th>
      <td>
        <% for (const visualisation of splashVisualisations) { %>
        <%- await visualisation %>
        <% } %>
      </td>
    </tr>
    <% } %>
    <tr>
      <th>Spectrum</th>
      <td class="spectrum" data-source="<%= spectrumUrl %>"></td>
    </tr>
  </tbody>
</table>

<% if (peaks.length > 0) { %>
<h1>Annotated peaks</h1>
<table>
  <tbody>
    <% for (const peak of peaks) { %>
    <tr>
      <th><%= peak.position.value %></th>
      <td class="prewrap"><%= peak.annotation.value %></td>
    </tr>
    <% } %>
  </tbody>
</table>
<% } %>