<% // https://github.com/idsm-src/server/blob/develop/service/src/main/webapp/templates/item/chebi/Class.vm

const name = (await select(`
  PREFIX ebi: <http://rdf.ebi.ac.uk/dataset/>
  PREFIX rdfs: <http://www.w3.org/2000/01/rdf-schema#>

  SELECT ?name FROM ebi:chebi WHERE
  {
    ?entity rdfs:label ?name
  }
`, [{ entity }])).at(0)?.name

const structuresExist = await ask(`
  PREFIX ebi: <http://rdf.ebi.ac.uk/dataset/>
  PREFIX rdf: <http://www.w3.org/1999/02/22-rdf-syntax-ns#>
  PREFIX sio: <http://semanticscience.org/resource/>

  ASK FROM ebi:chebi WHERE
  {
    ?S rdf:type sio:SIO_011120.
    ?S sio:SIO_000011 ?entity.
    ?S sio:SIO_000300 ?V.
  }
`, [{ entity }])

const imageUrl = entity.value.replace(/.+\/obo\/CHEBI_([0-9]+)$/, 'https://idsm.elixir-czech.cz/chemweb/chebi/compound/svg?id=$1')
%>

<span class="row">
  <% if (structuresExist) { %>
  <svg data-source="<%= imageUrl %>"></svg>
  <% } %>
  <a href="<%= entity.value %>"><%= name?.value ?? entity.value %></a>
</span>