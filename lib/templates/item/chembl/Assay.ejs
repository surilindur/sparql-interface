<% // https://github.com/idsm-src/server/blob/develop/service/src/main/webapp/templates/item/chembl/Assay.vm

const assay = (await select(`
  PREFIX ebi: <http://rdf.ebi.ac.uk/dataset/>
  PREFIX dcterms: <http://purl.org/dc/terms/>

  SELECT ?description FROM ebi:chembl WHERE
  {
    ?entity dcterms:description ?description
  }
`, [{ entity }])).at(0)
%>

<a href="<%= entity.value %>"><%= assay?.description?.value ?? entity.value %></a>