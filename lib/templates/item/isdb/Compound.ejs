<% // https://github.com/idsm-src/server/blob/develop/service/src/main/webapp/templates/item/isdb/Compound.vm

const regex = /.+\/(.+)_CMPD$/
const imageUrl = entity.value.replace(regex, 'https://idsm.elixir-czech.cz/chemweb/isdb/compound/svg?id=$1')
const title = entity.value.replace(regex, '$1')
%>

<span class="row">
  <img loading='lazy' data-source="<%= imageUrl %>">
  <a href="<%= entity.value %>"><%= title %></a>
</span>