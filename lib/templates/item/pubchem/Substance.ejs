<% // https://github.com/idsm-src/server/blob/develop/service/src/main/webapp/templates/item/pubchem/Substance.vm

const substance = (await select(`
  PREFIX pubchem: <http://rdf.ncbi.nlm.nih.gov/pubchem/>
  PREFIX sio: <http://semanticscience.org/resource/>

  SELECT ?compound FROM pubchem:substance WHERE
  {
    ?entity sio:CHEMINF_000477 ?compound
  }
`, [{ entity }])).at(0)

const compound = substance ? (await select(`
  PREFIX pubchem: <http://rdf.ncbi.nlm.nih.gov/pubchem/>
  PREFIX descriptor: <http://rdf.ncbi.nlm.nih.gov/pubchem/descriptor/>
  PREFIX sio: <http://semanticscience.org/resource/>
  PREFIX rdf: <http://www.w3.org/1999/02/22-rdf-syntax-ns#>

  SELECT ?name FROM pubchem:compound FROM descriptor:compound WHERE
  {
    ?compound sio:SIO_000008 [
      rdf:type sio:CHEMINF_000382 ;
      sio:SIO_000300 ?name
    ] .
  }
`, [{ compound: substance.compound }])).at(0) : undefined

const structuresExist = substance ? await ask(`
  PREFIX pubchem: <http://rdf.ncbi.nlm.nih.gov/pubchem/>
  PREFIX sio: <http://semanticscience.org/resource/>
  PREFIX rdf: <http://www.w3.org/1999/02/22-rdf-syntax-ns#>

  ASK FROM pubchem:compound WHERE
  {
    ?s rdf:type sio:SIO_011120 .
    ?s sio:SIO_000011 ?compound .
    ?s sio:SIO_000300 ?V .
  }
`, [{ compound: substance.compound }]) : false

const imageUrl = substance?.compound?.value?.replace(/.+\/pubchem\/compound\/CID([0-9]+)$/, 'https://idsm.elixir-czech.cz/chemweb/pubchem/compound/svg?id=$1')
%>

<span class="row">
  <% if (structuresExist) { %>
  <svg data-source="<%= imageUrl %>"></svg>
  <% } %>
  <a href="<%= entity.value %>"><%= compound?.name?.value ?? await label(entity) %></a>
</span>