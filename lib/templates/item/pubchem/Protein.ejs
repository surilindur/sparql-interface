<% // https://github.com/idsm-src/server/blob/develop/service/src/main/webapp/templates/item/pubchem/Protein.vm

const label = (await select(`
  PREFIX pubchem: <http://rdf.ncbi.nlm.nih.gov/pubchem/>
  PREFIX skos: <http://www.w3.org/2004/02/skos/core#>

  SELECT ?value FROM pubchem:protein WHERE {
    ?entity skos:prefLabel ?value
  }
`, [{ entity }])).at(0)?.value?.value ?? uriToLabel(entity.value)

const organism = (await select(`
  PREFIX pubchem: <http://rdf.ncbi.nlm.nih.gov/pubchem/>
  PREFIX skos: <http://www.w3.org/2004/02/skos/core#>
  PREFIX up: <http://purl.uniprot.org/core/>

  SELECT ?organism ?name FROM pubchem:protein FROM pubchem:taxonomy WHERE {
    ?entity up:organism ?organism .
    ?organism skos:prefLabel ?name .
  }
`, [{ entity }])).at(0)
%>

<span class="column">
  <a href="<%= entity.value %>"><%= label %></a>
  <% if (organism) { %>
  <small>
    <a href="<%= organism.organism.value %>"><%= organism.name.value %></a>
  </small>
  <% } %>
</span>